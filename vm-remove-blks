#!/usr/bin/env bash
set -euo pipefail

POOL="default"

VM="${1:?usage: vm-detach-blk VM [--pool POOL]}"
shift

while [[ $# -gt 0 ]]; do
  case "$1" in
    --pool) POOL="$2"; shift 2 ;;
    *) echo "unknown option: $1" >&2; exit 1 ;;
  esac
done

virsh dominfo "$VM" >/dev/null
virsh pool-info "$POOL" >/dev/null

echo "VM=$VM"
echo "POOL=$POOL"
echo

virsh domblklist "$VM" --details | awk '$2 == "disk" {print $3, $4}' |
while read -r target source; do
  vol="$(basename "$source")"

  case "$vol" in
    "$VM"-blk-[0-9][0-9])
      echo "detaching $target -> $source"
      virsh detach-disk "$VM" "$target" --persistent

      echo "deleting libvirt volume: pool=$POOL vol=$vol"
      virsh vol-delete --pool "$POOL" "$vol"

      echo "done: $vol"
      echo
      ;;
  esac
done
