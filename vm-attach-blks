#!/usr/bin/env bash
set -euo pipefail

POOL="default"
AMOUNT=5
SIZE="1G"
THIN=0

VM="${1:?usage: vm-attach-blk VM [--pool POOL] [--amount N] [--size SIZE] [--thin]}"
shift

while [[ $# -gt 0 ]]; do
  case "$1" in
    --pool)   POOL="$2"; shift 2 ;;
    --amount) AMOUNT="$2"; shift 2 ;;
    --size)   SIZE="$2"; shift 2 ;;
    --thin)   THIN=1; shift ;;
    *) echo "unknown option: $1" >&2; exit 1 ;;
  esac
done

virsh dominfo "$VM" >/dev/null
virsh pool-info "$POOL" >/dev/null

echo "VM=$VM"
echo "POOL=$POOL"
echo "AMOUNT=$AMOUNT"
echo "SIZE=$SIZE"
echo "THIN=$THIN"
echo

for i in $(seq 0 $((AMOUNT - 1))); do
  n=$(printf "%02d" "$i")
  devletter=$(printf "\\$(printf '%03o' $((98+i)))")   # b,c,d...
  vol="$VM-blk-$n"
  target="vd$devletter"

  echo "creating libvirt volume: pool=$POOL name=$vol size=$SIZE"

  if [[ "$THIN" -eq 1 ]]; then
    virsh vol-create-as "$POOL" "$vol" "$SIZE" --allocation 0
  else
    virsh vol-create-as "$POOL" "$vol" "$SIZE"
  fi

  path="$(virsh vol-path --pool "$POOL" "$vol")"

  echo "volume path: $path"
  echo "attaching to $VM as $target"

  virsh attach-disk "$VM" "$path" "$target" \
    --targetbus virtio \
    --driver qemu \
    --subdriver raw \
    --cache none \
    --io native \
    --persistent

  echo "done: $vol -> $target"
  echo
done

